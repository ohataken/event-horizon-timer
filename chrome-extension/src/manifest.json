{
  "name": "event-horizon-timer",
  "description": "Event Horizon Timer",
  "version": "0.0.1",
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "icons": {
    "16": "icon_016.png",
    "32": "icon_032.png",
    "48": "icon_048.png",
    "128": "icon_128.png"
  },
  "side_panel": {
    "default_path": "dest/index.html"
  },  
  "options_page": "dest/options_page.html",  
  "host_permissions": [
    "https://example.com/*"
  ],  
  "manifest_version": 3
}
